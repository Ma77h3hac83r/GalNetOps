---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import Button from '../components/Button.astro';

const url = Astro.url;
const errorParam = url.searchParams.get('error');
const redirectParam = url.searchParams.get('redirect');
---

<DashboardLayout title="Login - GalNetOps">
  <div class="p-6 max-w-md mx-auto">
    <div class="mb-8">
      <h1>Login</h1>
      <p class="text-text-secondary mt-2">
        Sign in to your GalNetOps account.
      </p>
    </div>

    {errorParam && (
      <div class="card border-red-500 mb-6">
        <h3 class="text-red-400 mb-2">Login Failed</h3>
        <p class="text-text-secondary">{decodeURIComponent(errorParam)}</p>
      </div>
    )}

    <div class="card">
      <form method="POST" action="/api/auth/login" class="space-y-4">
        <input type="hidden" name="redirect" value={redirectParam || ''} />

        <div>
          <label for="email" class="block mb-2">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2 bg-bg-primary border border-border rounded-button text-text-primary focus:outline-none focus:border-accent"
            placeholder="your.email@example.com"
          />
        </div>

        <div>
          <label for="password" class="block mb-2">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            class="w-full px-4 py-2 bg-bg-primary border border-border rounded-button text-text-primary focus:outline-none focus:border-accent"
            placeholder="••••••••"
          />
        </div>

        <div class="flex gap-3 pt-2">
          <Button variant="primary" type="submit">
            Login
          </Button>
          <Button variant="secondary" href="/register" type="button">
            Create Account
          </Button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

