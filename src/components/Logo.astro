---
interface Props {
  variant?: 'mark' | 'lockup';
  size?: 'small' | 'medium' | 'large';
}

const { variant = 'lockup', size = 'medium' } = Astro.props;

const sizeClasses = {
  small: { mark: 'h-6', text: 'text-lg' },
  medium: { mark: 'h-8', text: 'text-xl' },
  large: { mark: 'h-10', text: 'text-2xl' },
};

const currentSize = sizeClasses[size];
---

<div class="flex items-center gap-3">
  <!-- Galactic Network Node Mark -->
  <svg
    class={currentSize.mark}
    viewBox="0 0 32 32"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Connection Arc 1 -->
    <path
      d="M 8 16 Q 16 8, 24 16"
      stroke="#4D9FFF"
      stroke-width="1.5"
      fill="none"
      stroke-linecap="round"
    />
    <!-- Connection Arc 2 -->
    <path
      d="M 12 24 Q 16 20, 20 24"
      stroke="#4D9FFF"
      stroke-width="1.5"
      fill="none"
      stroke-linecap="round"
    />
    <!-- Node 1 -->
    <circle cx="8" cy="16" r="3" fill="#4D9FFF" />
    <!-- Node 2 -->
    <circle cx="24" cy="16" r="3" fill="#4D9FFF" />
    <!-- Node 3 -->
    <circle cx="12" cy="24" r="2.5" fill="#4D9FFF" />
    <!-- Node 4 -->
    <circle cx="20" cy="24" r="2.5" fill="#4D9FFF" />
    <!-- Node 5 (smaller accent) -->
    <circle cx="16" cy="10" r="2" fill="#4D9FFF" />
  </svg>

  {variant === 'lockup' && (
    <span class={`${currentSize.text} font-semibold text-text-primary`} style="font-family: 'Lexend', sans-serif; font-weight: 600;">
      GalNetOps
    </span>
  )}
</div>

